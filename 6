ctk.set_appearance_mode("dark")
ctk.set_default_color_theme("green")

root = ctk.CTk()
root.title("Задание №6")
root.geometry("500x500")
my_font = ctk.CTkFont(family="Roboto", size=20)

label = ctk.CTkLabel(master=root)
label.configure(
    text="Выберите код:",
    font=my_font,
    text_color="white"
)

entry = ctk.CTkEntry(master=root)
entry.configure(
    justify="center",
    font=my_font,
    width=150,
    height=50
)
entry.insert(0, "111")
entry.configure(state="readonly")

scrollable_frame = ctk.CTkScrollableFrame(master=root)
scrollable_frame.configure(height=250, width=100)

scrollable_frame_2 = ctk.CTkScrollableFrame(master=root)
scrollable_frame_2.configure(height=250, width=100)

scrollable_frame_3 = ctk.CTkScrollableFrame(master=root)
scrollable_frame_3.configure(height=250, width=100)

rows, columns = 3, 3
for i in range(rows):
    if i == 1:
        root.rowconfigure(index=i, weight=2)
    else:
        root.rowconfigure(index=i, weight=1)

for i in range(columns):
    root.columnconfigure(index=i, weight=1)
scrollable_frame.grid(row=1, column=0)
scrollable_frame_2.grid(row=1, column=0)
scrollable_frame_3.grid(row=1, column=0)

lst_handlers = []
for i in range(10):
    handler_i = lambda i_actual=i: handle_button_press(i_actual + 1)
    lst_handlers.append(handler_i)

# кнопки внутри scrollable_frame:
lst_btns = []
for i in range(10):
    btn_i = ctk.CTkButton(master=scrollable_frame)
    if i == 9:
        btn_i.configure(text=f"0", font=my_font, width=50, height=40)
    else:
        btn_i.configure(text=f"{i + 1}", font=my_font, width=50, height=40)
    btn_i.configure(command=lst_handlers[i])  # к каждой кнопке привязываем свой промежуточный хендлер
    lst_btns.append(btn_i)

# внутренняя сетка рамки scrollable_frame:
rows_2, columns_2 = 10, 1
for i in range(rows_2):
    scrollable_frame.rowconfigure(index=i, weight=1)
for i in range(columns_2):
